// mumax/bloch_dmi_minus.mx3
//
// Domain wall with interfacial DMI: D = -1e-4 J/m²
// Matches src/bin/bloch_dmi.rs parameters exactly.
//
// Run on SCARF:
//   mumax3 -http "" -o Dminus_out bloch_dmi_minus.mx3

SetGridSize(256, 64, 1)
SetCellSize(5e-9, 5e-9, 5e-9)

Msat  = 8e5
Aex   = 13e-12
Ku1   = 500
anisU = vector(0, 0, 1)
Dind  = -1e-4         // interfacial DMI (J/m²), opposite sign

// Disable demag to match Rust benchmark
EnableDemag = false

// No external field
B_ext = vector(0, 0, 0)

// High damping for relaxation
alpha = 0.5

// Initial condition: Néel-like domain wall at centre.
// For -D: chirality flips, so mx < 0 at wall centre.
m = TwoDomain(0, 0, -1,   -1, 0, 0,   0, 0, 1)

// Relax to equilibrium
Relax()

// Save full magnetisation
SaveAs(m, "m_final_Dminus")
